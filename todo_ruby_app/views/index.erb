<!doctype html>
<html>
<head>
  <meta charset="utf-8">
  <title>Ruby To-Do</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/app.css" rel="stylesheet">
</head>

<body class="bg-dark text-white">
<div class="container py-5" style="max-width:800px">

  <h1 class="mb-3">To-Do</h1>
  <p class="text-muted">Ruby + Sinatra + SQLite</p>

  <form method="post" action="/add?filter=<%= filter %>" class="d-flex gap-2 mb-3">
    <input name="text" class="form-control form-control-lg" placeholder="Add task..." required>
    <button class="btn btn-light">Add</button>
  </form>

  <div class="mb-3">
    <strong><%= active_count %></strong> active •
    <strong><%= completed_count %></strong> completed
  </div>

  <div class="btn-group mb-3">
    <a class="btn btn-outline-light <%= 'active' if filter=='all' %>" href="/?filter=all">All</a>
    <a class="btn btn-outline-light <%= 'active' if filter=='active' %>" href="/?filter=active">Active</a>
    <a class="btn btn-outline-light <%= 'active' if filter=='completed' %>" href="/?filter=completed">Completed</a>
  </div>

  <ul class="list-group">
    <% if todos.empty? %>
      <li class="list-group-item bg-dark text-white-50">No tasks yet</li>
    <% end %>

    <% todos.each do |t| %>
      <li class="list-group-item bg-dark text-white d-flex justify-content-between">
        <div>
          <form method="post" action="/toggle?filter=<%= filter %>" style="display:inline">
            <input type="hidden" name="id" value="<%= t["id"] %>">
            <button class="btn btn-sm <%= t["completed"]==1 ? "btn-success" : "btn-outline-light" %>">
              ✓
            </button>
          </form>

          <span class="<%= 'text-decoration-line-through text-muted' if t['completed']==1 %>">
            <%= t["text"] %>
          </span>
        </div>

        <form method="post" action="/delete?filter=<%= filter %>">
          <input type="hidden" name="id" value="<%= t["id"] %>">
          <button class="btn btn-sm btn-outline-danger">Delete</button>
        </form>
      </li>
    <% end %>
  </ul>

  <form method="post" action="/clear-completed?filter=<%= filter %>" class="mt-3">
    <button class="btn btn-link text-white-50">Clear completed</button>
  </form>

</div>
</body>
</html>
